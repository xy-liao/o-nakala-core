  "screenshots": [
    {
      "src": "screenshots/dashboard-desktop.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Dashboard view on desktop"
    },
    {
      "src": "screenshots/dashboard-mobile.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Dashboard view on mobile"
    }
  ],
  "shortcuts": [
    {
      "name": "Autonomous Generation",
      "short_name": "Auto Generate",
      "description": "Generate metadata automatically from files",
      "url": "/?tab=autonomous",
      "icons": [
        {
          "src": "icons/icon-96x96.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Template Designer",
      "short_name": "Templates",
      "description": "Create custom metadata templates",
      "url": "/template-designer.html",
      "icons": [
        {
          "src": "icons/icon-96x96.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Analytics",
      "short_name": "Analytics",
      "description": "View predictive analytics and insights",
      "url": "/?tab=analytics",
      "icons": [
        {
          "src": "icons/icon-96x96.png",
          "sizes": "96x96"
        }
      ]
    }
  ],
  "share_target": {
    "action": "/?tab=autonomous",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "file",
          "accept": ["*/*"]
        }
      ]
    }
  },
  "file_handlers": [
    {
      "action": "/?tab=autonomous",
      "accept": {
        "text/csv": [".csv"],
        "application/json": [".json"],
        "application/pdf": [".pdf"],
        "image/*": [".jpg", ".jpeg", ".png", ".gif", ".webp"],
        "text/plain": [".txt", ".md"]
      }
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "nakala",
      "url": "/?nakala=%s"
    }
  ]
}